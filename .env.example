# Base de dados PostgreSQL
# Neon: mesma URL em DATABASE_URL e DIRECT_URL – ver docs/CONFIG-NEON.md
# Supabase: ver docs/CONFIG-SUPABASE.md (duas URLs diferentes)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth (alterar em produção)
JWT_SECRET="trocar-em-producao-por-uma-chave-segura"

# Primeiro admin (usado pelo seed)
ADMIN_EMAIL="admin@roveplus.com"
ADMIN_PASSWORD="admin123"

# WhatsApp Business (+244 933623143)
# Para envio automático, configurar API (Meta Cloud API ou Twilio)
WHATSAPP_PHONE="244933623143"
WHATSAPP_API_URL=""
WHATSAPP_TOKEN=""

# Frontend (URL da API em produção; deixar vazio se mesmo domínio)
# VITE_API_URL="https://seu-dominio.vercel.app"

# Cron alertas (opcional; usar com Vercel Cron)
# CRON_SECRET="um-secret-qualquer"
