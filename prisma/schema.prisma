// Rove+ Painel - PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Admin / utilizadores do painel (login)
model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  whatsapp  String?  // contacto WhatsApp (opcional)
  password  String   // hash bcrypt
  role      String   @default("geral") // admin | geral | netflix | iptv (suporte = geral)
  status    String   @default("ativo") // ativo | suspenso
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
}

// Clientes (Netflix + IPTV)
model Client {
  id          Int       @id @default(autoincrement())
  nome        String
  whatsapp    String
  localizacao String?   // localização do cliente
  servico     String    // netflix | iptv
  plano       String    // partilhada | express | premium | mensal | etc.
  servidorId    Int?
  servidor      Servidor?   @relation(fields: [servidorId], references: [id])
  revendedorId  Int?        @map("revendedor_id")
  revendedor    Revendedor? @relation(fields: [revendedorId], references: [id])
  perfil        String?     // perfil Netflix ou linha/username IPTV
  pin           String?     // PIN do perfil Netflix (opcional)
  // IPTV extra (opcional)
  iptvUser    String?
  iptvPass    String?
  iptvMac     String?
  iptvM3u     String?
  dataInicio  DateTime  @map("data_inicio")
  dataFim     DateTime  @map("data_fim")
  valor         Decimal   @db.Decimal(10, 2)  // preço mensal
  inscricaoPaga Boolean?  @map("inscricao_paga") // Netflix: se já pagou a inscrição
  salaId       Int?      @map("sala_id")        // Netflix Plano Room: sala (conta) gerida no painel
  sala         Sala?     @relation(fields: [salaId], references: [id])
  status        String    @default("ativo") // ativo | vencido | cancelado
  indicacoes    Int       @default(0)       // total de indicações deste cliente
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  indicacoesComoIndicador Indicacao[] @relation("indicador")

  @@map("clients")
}

// Salas Netflix (Plano Room) – contas em que os clientes estão; data fim é da sala (4 usuários partilham)
model Sala {
  id          Int       @id @default(autoincrement())
  nome        String    // ex: Sala 1, Conta A
  email       String?   // email da conta Netflix
  senha       String?   // senha da conta Netflix
  observacoes String?
  dataFim     DateTime? @map("data_fim") // data fim partilhada por todos os clientes da sala
  status      String    @default("ativo") // ativo | suspenso
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clients Client[]
  @@map("salas")
}

// Servidores IPTV
model Servidor {
  id            Int       @id @default(autoincrement())
  nome          String
  tipo          String    @default("principal") // principal | secundario
  servidorId    Int?      @map("servidor_id")   // servidor primário (quando tipo=secundario)
  servidor      Servidor? @relation("primary", fields: [servidorId], references: [id])
  secundarios   Servidor[] @relation("primary")
  totalClientes Int      @default(0) @map("total_clientes")
  status        String    @default("online")    // online | instável | offline
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clients     Client[]
  revendedores Revendedor[]
  @@map("servidores")
}

// Revendedores do serviço IPTV
model Revendedor {
  id          Int       @id @default(autoincrement())
  nome        String
  contacto    String    // telefone / WhatsApp
  servidorId  Int?      @map("servidor_id")
  servidor    Servidor? @relation(fields: [servidorId], references: [id])
  observacoes String?
  status      String    @default("ativo") // ativo | suspenso
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clients Client[]

  @@map("revendedores")
}

// Indicações (quem indicou quem)
model Indicacao {
  id               Int      @id @default(autoincrement())
  indicadorId      Int      @map("indicador_id")
  indicador        Client   @relation("indicador", fields: [indicadorId], references: [id], onDelete: Cascade)
  indicadoNome     String   @map("indicado_nome")
  indicadoWhatsapp String   @map("indicado_whatsapp")
  status           String   @default("pendente") // pendente | confirmada
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("indicacoes")
}

// Log de alterações (auditoria)
model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  action     String   // create_client | update_client | renew | suspend | delete_client | etc.
  entity     String   // client | servidor | indicacao | user
  entityId   Int?     @map("entity_id")
  details    String?  // JSON ou texto
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
