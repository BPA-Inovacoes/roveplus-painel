# Porta (Railway define PORT automaticamente)
PORT=8080

# Obrigatório em produção — mesmo valor no painel Rove+ (Vercel): WHATSAPP_TOKEN
WHATSAPP_TOKEN=gerar_um_token_longo_aleatorio

# Sessão WhatsApp Web (volume persistente no Railway: /data/.wwebjs_auth)
WWEBJS_AUTH_PATH=/data/.wwebjs_auth

# Chromium no Docker (já definido no Dockerfile)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
